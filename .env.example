UPSTASH_REDIS_REST_URL="https://...upstash.io"
UPSTASH_REDIS_REST_TOKEN="gQAAAA..."


# Mật khẩu chung khu quản trị /admin (FR1). Đổi giá trị này khi bàn giao.
ADMIN_PASSWORD="langbiang"
# Muối băm cookie phiên đăng nhập (tuỳ chọn; đổi sẽ đăng xuất mọi phiên).
# ADMIN_AUTH_SALT="doi-chuoi-nay-khi-trien-khai"
# Vercel Blob để tải ảnh lên (FR7). LƯU Ý: store PHẢI ở chế độ Public —
# store Private cho URL *.private.blob... và khách sẽ nhận 403, ảnh không hiện.
BLOB_STORE_ID="store..."
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Hộp thư gửi đi (Gmail). Chọn 1 trong 2 cách xác thực:
#
# GMAIL_USER là địa chỉ Gmail dùng để gửi (cũng là account đã bấm "cho phép"
# khi lấy refresh token). Thư đi sẽ hiện From = địa chỉ này.
GMAIL_USER=...
#
# Cách A — OAuth2 (KHUYẾN NGHỊ, ổn định lâu dài). Xem docs/email-oauth2-setup.md.
GMAIL_OAUTH_CLIENT_ID=...
GMAIL_OAUTH_CLIENT_SECRET=...
GMAIL_OAUTH_REFRESH_TOKEN=...
#
# Cách B — App Password (dự phòng, hay bị thu hồi). Chỉ cần khi KHÔNG dùng OAuth2:
# GMAIL_APP_PASSWORD=...
MAIL_FROM_NAME="Trăng Sáng Langbiang"
