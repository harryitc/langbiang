UPSTASH_REDIS_REST_URL="https://...upstash.io"
UPSTASH_REDIS_REST_TOKEN="gQAAAA..."


# Mật khẩu chung khu quản trị /admin (FR1). Đổi giá trị này khi bàn giao.
ADMIN_PASSWORD="langbiang"
# Muối băm cookie phiên đăng nhập (tuỳ chọn; đổi sẽ đăng xuất mọi phiên).
# ADMIN_AUTH_SALT="doi-chuoi-nay-khi-trien-khai"
# Vercel Blob để tải ảnh lên (FR7). LƯU Ý: store PHẢI ở chế độ Public —
# store Private cho URL *.private.blob... và khách sẽ nhận 403, ảnh không hiện.
BLOB_STORE_ID="store..."
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Hộp thư gửi đi (Gmail SMTP)
# GMAIL_APP_PASSWORD là "mật khẩu ứng dụng" 16 ký tự tạo trong tài khoản Google,
# KHÔNG phải mật khẩu đăng nhập. Cần bật xác thực 2 bước trước mới tạo được.
GMAIL_USER=...
GMAIL_APP_PASSWORD=...
MAIL_FROM_NAME="Trăng Sáng Langbiang"
